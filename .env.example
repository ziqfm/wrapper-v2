# wrapper-v2 environment template.
# Copy to .env and fill in. Anything left commented uses the default.

# Public host port that maps onto the daemon's HTTP server.
# Defaults to 80 inside the container; set this if your host already has
# something bound to :80 (nginx, caddy, IIS, Docker Desktop, ...).
# HTTP_PORT=8080

# Target arch. Phase 1 only supports x86_64. arm64-v8a is planned for Phase 4.
# TARGET_ARCH=x86_64

# Build with Dobby-based debug hooks (cert-pinning bypass for mitmproxy etc).
# Off by default. Only flip ON for diagnostic builds, never production.
# WRAPPER_DEBUG_HOOKS=OFF

# URL the CI workflow downloads the APKMirror .apkm bundle from.
# This single bundle contains base.apk plus all arch and DPI splits, so
# Phase 1 (x86_64) and Phase 4 (arm64-v8a) both pull from the same URL.
# Set as a GitHub Actions secret, not committed here. Local builds do not
# need this - run tools/fetch-apk.sh + tools/extract-libs.sh manually.
# APK_URL=https://example.invalid/apple-music-3.6.0-beta-1109.apkm

# ---------------------------------------------------------------------------
# Daemon runtime (read inside the chroot, prefix WRAPPER_*)
# ---------------------------------------------------------------------------

# Bind address and port the daemon listens on inside the chroot.
# WRAPPER_HOST=0.0.0.0
# WRAPPER_PORT=80

# Apple-lib working directory (FairPlay key cache, mpl_db, etc).
# Must exist inside rootfs/. The default matches upstream wrapper.
# WRAPPER_BASE_DIR=/data/data/com.apple.android.music/files

# Slash-separated 9-tuple identifying the fake "Apple Music Android client"
# the daemon presents to Apple's servers. Order:
#   ClientId/VersionId/PlatformId/ProductVersion/DeviceModel/BuildVersion/
#   LocaleId/LanguageId/AndroidID
# Default is the same Galaxy-S9 fingerprint upstream wrapper uses.
# WRAPPER_DEVICE_INFO=Music/4.9/Android/10/Samsung S9/7663313/en-US/en-US/dc28071e981c439e

# Set to 0 to skip Apple lib initialization at startup. With this flag set,
# the daemon binds the HTTP server but does NOT call into libstoreservicescore
# / libmediaplatform / libandroidappmusic. Useful for /health-only smoke
# tests on builds where you have not staged the Apple libraries yet.
# WRAPPER_APPLE_INIT=1
